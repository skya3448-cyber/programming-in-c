5.bubble sort
#include <stdio.h>
int main() {
 int arr[100], n, i, j, temp;
 printf("Enter the number of elements: ");
 scanf("%d", &n);
 printf("Enter %d integers:\n", n);
 for (i = 0; i < n; i++) {
 scanf("%d", &arr[i]);
 }
 // Bubble Sort Logic
 for (i = 0; i < n - 1; i++) { // Outer loop for number of passes
 for (j = 0; j < n - i - 1; j++) { // Inner loop for comparisons
 if (arr[j] > arr[j + 1]) {
 // Swap elements if they are in the wrong order
 temp = arr[j];
 arr[j] = arr[j + 1];
 arr[j + 1] = temp;
 }
 }
 }
 printf("Sorted array in ascending order:\n");
 for (i = 0; i < n; i++) {
 printf("%d ", arr[i]);
 }
 printf("\n");
 return 0;
}

6.array of integers
#include <stdio.h>
#include <stdlib.h> 
#include <time.h> // Required for time() to seed the random generator
int main() {
 int n, i;
 int *ptr;
 printf("Enter the number of elements: ");
 scanf("%d", &n);

 ptr = (int*)malloc(n * sizeof(int));

 if (ptr == NULL) {
 printf("Memory not allocated. Program exiting.\n");
 return 0;
 }

 srand(time(0));

 printf("\nGenerated Random Numbers:\n");
 for (i = 0; i < n; i++) {
 ptr[i] = rand() % 100; // Generates numbers between 0 and 99
 printf("Element %d: %d\n", i + 1, ptr[i]);
 }

 free(ptr);
 printf("\nMemory successfully freed.\n");
 return 0;
}

